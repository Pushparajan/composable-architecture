# Publishing Pipeline Environment Variables
# Copy this file to .env.local and fill in your values

# IndexNow API key (generate a unique key for your site)
# The key file must be placed in public/<key>.txt
INDEXNOW_KEY=your-indexnow-key-here

# Vercel Cron secret (for protecting cron job endpoints)
# Set this in Vercel dashboard > Settings > Environment Variables
CRON_SECRET=your-cron-secret-here

# Webhook secret for publish hooks (optional, for HMAC validation)
PUBLISH_WEBHOOK_SECRET=your-webhook-secret-here

# Admin secret for community review approvals
ADMIN_SECRET=your-admin-secret-here

# Google Search Console API (optional, for programmatic sitemap submission)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Platform API keys for community distribution (optional)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# LINKEDIN_ACCESS_TOKEN=

# DEVTO_API_KEY=
