{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/jobs/indexnow",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/jobs/google-sitemap",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/jobs/distribute",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/jobs/community-review",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/rss.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/rss+xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
